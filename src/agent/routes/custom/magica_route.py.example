import os
import aiohttp
from typing import List, Optional
from agent.routes.base import BaseRoute, RouteStatus

class MagicaCustomRoute(BaseRoute):
    """Example of a custom execution route.
    
    To activate this route:
    1. Rename this file to remove the '.example' suffix (e.g. 'magica_route.py').
    2. Configure environment variables like:
       ROUTE_MAGICA_STATUS="on" (or "primary" / "secondary" / "urgent_only")
       ROUTE_MAGICA_PRIORITY=5
    """

    @property
    def name(self) -> str:
        # Configuration keys will automatically use ROUTE_MAGICA_STATUS / ROUTE_MAGICA_PRIORITY
        return "magica"

    @property
    def default_status(self) -> RouteStatus:
        return RouteStatus.OFF

    @property
    def default_priority(self) -> int:
        return 50

    @property
    def supported_models(self) -> List[str]:
        # Models supported by this route (or ["*"] for all models)
        return ["magica/", "claude-3-5", "*"]

    async def execute(
        self,
        prompt: str,
        model: str,
        system_instructions: Optional[str] = None,
        timeout: Optional[float] = None,
        conversation_id: Optional[str] = None,
    ) -> Optional[str]:
        api_key = os.environ.get("MAGICA_API_KEY")
        if not api_key:
            print("[ROUTE: magica] Skipped: MAGICA_API_KEY not set.")
            return None

        # Build prompt format
        full_prompt = prompt
        if system_instructions:
            full_prompt = f"[System Instructions]\n{system_instructions}\n\n[User Prompt]\n{prompt}"

        # Example 1: Clean/strip custom route prefix if present
        target_model = model.replace("magica/", "")

        # Example 2: Model Mapping (alias resolution)
        # Developers can map generic keywords/aliases to specific provider versions:
        target_lower = target_model.lower()
        if target_lower in ("", "*", "default"):
            target_model = "gemini-1.5-flash"  # Default fallback model
        elif "flash" in target_lower:
            target_model = "gemini-1.5-flash"
        elif "pro" in target_lower:
            target_model = "gemini-1.5-pro"
        elif "sonnet" in target_lower:
            target_model = "claude-3-5-sonnet-20241022"

        # Example 3: Failover candidate chain definition
        # Define fallback models in order of priority if the primary model rate-limits or fails
        failovers = ["gemini-1.5-flash", "claude-3-5-sonnet-20241022"]
        candidates = [target_model]
        for fallback in failovers:
            if fallback not in candidates:
                candidates.append(fallback)

        # Example HTTP request loop iterating through candidate models
        for candidate_model in candidates:
            # Clean model parameter used in request payload
            print(f"[ROUTE: magica] Attempting execution with candidate: {candidate_model}")
            
            url = "https://api.magica.ai/v1/chat/completions"
            headers = {
                "Authorization": f"Bearer {api_key}",
                "Content-Type": "application/json"
            }
            payload = {
                "model": candidate_model,
                "messages": [
                    {"role": "user", "content": full_prompt}
                ],
                "temperature": 0.2
            }

            try:
                async with aiohttp.ClientSession() as session:
                    async with session.post(url, json=payload, headers=headers, timeout=timeout or 60.0) as resp:
                        if resp.status == 200:
                            data = await resp.json()
                            return data["choices"][0]["message"]["content"]
                        else:
                            print(f"[ROUTE: magica] Model {candidate_model} failed with status {resp.status}")
            except Exception as e:
                print(f"[ROUTE: magica] Request failed for model {candidate_model}: {e}")

        return None
