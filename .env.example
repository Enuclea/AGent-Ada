# API Keys & Credentials
DISCORD_BOT_TOKEN="your-discord-bot-token"
GEMINI_API_KEY="your-gemini-developer-key"

# Route Customizations
ROUTE_AGY_STATUS="primary"
ROUTE_GROK_STATUS="secondary"
ROUTE_OLLAMA_STATUS="off"

# Loop controls
VERIFICATION_LOOP_MINUTES=10

# Plugin System (disabled by default — opt-in required)
# WARNING: Enabling plugins allows outside code to execute in-process.
# Reasonable precautions are taken (AST scanning, cryptographic signatures,
# binary artifact rejection), but accepting use accepts potential risk.
# Security-in-depth should extend to host-level and network-level monitoring.
ADA_ENABLE_PLUGINS=0

# Pinned plugin checksums (SHA-256). Both the developer public key and these
# pinned hashes live in this read-only .env. Even with a valid signature,
# a plugin must match its pinned checksum or it MUST NOT load.
# Format: "pluginname:sha256hex,pluginname:sha256hex"
# Leave empty to skip checksum verification (not recommended in production).
ADA_APPROVED_PLUGIN_CHECKSUMS=""

# Ollama-Compatible Endpoint / Keyless Inference (disabled by default — opt-in required)
# This endpoint provides zero-cost LLM inference by wrapping the agy CLI in a
# Bubblewrap sandbox. It binds an OAuth token into the sandboxed process with
# network access. While constrained by multiple isolation layers (see SECURITY.md),
# enabling it accepts that a live credential exists inside the sandbox namespace.
# Recommended only for monitored hosts where bwrap is available.
#
# When DISABLED (default): LLM inference requires either:
#   - A configured secondary route (ROUTE_GROK_STATUS, ROUTE_OLLAMA_STATUS, etc.), OR
#   - A Gemini API key (GEMINI_API_KEY above — a free-tier key works fine here)
# When ENABLED: Keyless inference via agy's OAuth flow, zero API cost.
ADA_ENABLE_OLLAMA_ENDPOINT=0
