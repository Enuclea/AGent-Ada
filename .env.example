# ===========================================================================
# 🚀 MINIMUM REQUIRED CONFIGURATION
# ===========================================================================

# Gemini API Key (Required for primary route LLM inference)
# Get a key from Google AI Studio. A free-tier key works fine here.
GEMINI_API_KEY="your-gemini-developer-key"

# Dashboard authentication credentials
DASHBOARD_USERNAME="admin"
DASHBOARD_PASSWORD="change-me-to-a-secure-password"

# Cryptographic token for internal container-to-container API validation
INTERNAL_API_SECRET="generate-a-32-byte-hex-secret-here"


# ===========================================================================
# 🛡️ SECURITY & SANDBOXING CONFIGURATION
# ===========================================================================

# Enforce host-level subprocess sandboxing (bwrap)
#   - 0: Sandbox ON (Default, recommended for security)
#   - 1: Sandbox OFF (Only for trusted/container-enforced environments)
ADA_DISABLE_SANDBOX=0


# ===========================================================================
# ⚡ OPTIONAL FEATURES & INTEGRATIONS
# ===========================================================================

# --- 💬 Discord Bot Integration ---
# To enable, set DISCORD_BOT_TOKEN and change RUN_DISCORD_BOT to true.
# DISCORD_BOT_TOKEN="your-discord-bot-token"
RUN_DISCORD_BOT=false

# --- 🖥️ Remote Execution Workers ---
# Shared API key for fail-closed worker authentication.
# WORKER_API_KEY="your-high-entropy-worker-key"
# ALLOW_UNSECURE_WORKER=false

# --- 🍯 Ollama Honeypot / Keyless Inference ---
# Provides zero-cost LLM inference by wrapping the agy CLI in a Bubblewrap sandbox.
# 0: Disabled (Default) | 1: Enabled (Requires agy CLI and auth)
ADA_ENABLE_OLLAMA_ENDPOINT=0

# --- 🔌 Dynamic Plugin System ---
# 0: Disabled (Default) | 1: Enabled (Allows outside code execution in-process)
ADA_ENABLE_PLUGINS=0

# Pinned plugin SHA-256 checksums to permit loading.
# Format: "pluginname:sha256hex,pluginname:sha256hex"
ADA_APPROVED_PLUGIN_CHECKSUMS=""


# ===========================================================================
# ⚙️ ADVANCED SYSTEM PATHS & ROUTING
# ===========================================================================
ROUTE_AGY_STATUS="primary"
ROUTE_GROK_STATUS="secondary"
ROUTE_OLLAMA_STATUS="off"
VERIFICATION_LOOP_MINUTES=10
